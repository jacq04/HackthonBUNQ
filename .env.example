# Copy to .env and fill in.

# === Backend / FastAPI ===
ENV=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
# Public URL exposed to bunq for webhooks (ngrok or Railway domain in dev).
PUBLIC_BASE_URL=http://localhost:8000
# HMAC secret for signing reputation passports.
PASSPORT_HMAC_SECRET=change-me-in-prod

# === Supabase ===
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres direct connection (used only for migrations + server-side RLS-bypass reads).
SUPABASE_DB_URL=postgresql://postgres:...@db.YOUR-PROJECT.supabase.co:5432/postgres

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=
# Pin model versions. No -latest aliases.
CLAUDE_REASONER_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# === TigerBeetle ===
TIGERBEETLE_ADDRESSES=127.0.0.1:3000
TIGERBEETLE_CLUSTER_ID=0

# === bunq (sandbox) ===
# Optional — the backend can run multi-user without a top-level key.
# Set this only if you want a single default identity authenticated from .env.
BUNQ_API_KEY=
BUNQ_BASE_URL=https://public-api.sandbox.bunq.com/v1
BUNQ_DEVICE_DESCRIPTION=kitty-hackathon-dev
BUNQ_WEBHOOK_SECRET=

# Multi-sandbox-user context cache. Each user gets <label>.json in this dir.
# Toolkit-compatible JSON schema (same as bunq_toolkit's bunq_context.json).
BUNQ_CONTEXT_DIR=~/.kitty/bunq-contexts
BUNQ_DEFAULT_LABEL=default
# If set, overrides the dir with a single file (useful for toolkit interop —
# e.g. BUNQ_CONTEXT_FILE=./bunq_context.json lets the toolkit scripts and our
# backend share one session).
BUNQ_CONTEXT_FILE=

# === Mobile (expose via app config) ===
# These are read by the Expo client — mirror SUPABASE_URL/ANON_KEY there.
